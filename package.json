{
  "name": "sub-cipher",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "tsc -b && vite build",
    "build:server": "esbuild src/server/index.ts --bundle --platform=node --format=cjs --outfile=dist/server/index.cjs",
    "lint": "oxlint",
    "test": "vitest run",
    "preview": "vite preview",
    "devvit:playtest": "npx devvit playtest",
    "devvit:upload": "npx devvit upload"
  },
  "dependencies": {
    "@devvit/web": "0.13.8",
    "@hono/node-server": "^1.19.14",
    "hono": "^4.12.30",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  },
  "license": "BSD-3-Clause"
}
